---
// site/src/components/RecentNow.astro - interests block for homepage grid
const updated = '2026-05-23';
const interests = [
  'Where LLMs lose the plot',
  'Distributed systems and the messes they make',
  'Tinkering with robots',
  'How brains pull off learning',
  'Language, thought, and what came first',
];
---
<section class="posts bg-surface-soft rounded-lg p-6 h-full">
  <h2 class="text-[1.05rem] font-semibold mb-5">Interests</h2>
  <div class="text-[12px] font-mono text-muted opacity-60 tracking-wide">
    <span>Updated {updated}</span>
  </div>
  <ul class="mt-3 space-y-1.5 text-[15px] leading-snug list-disc pl-4">
    {interests.map((i) => <li>{i}</li>)}
  </ul>
</section>
