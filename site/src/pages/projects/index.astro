---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Description from '../../components/Description.astro';
import TagList from '../../components/TagList.astro';
import PostCover from '../../components/PostCover.astro';
import Icon from '../../components/Icon.astro';
import FilterScript from '../../components/FilterScript.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const items = (await getCollection('projects'))
  .sort((a, b) => b.data.year - a.data.year);

const stackSet = new Set<string>();
items.forEach((p) => p.data.stack.forEach((t) => stackSet.add(t)));
const stack = Array.from(stackSet).sort();
---
<BaseLayout title="Projects - Richie Moluno">
  <main class="max-w-content mx-auto px-6 pb-4 flex flex-col min-h-[calc(100vh-8rem)]">
    <header class="mt-12">
      <blockquote class="intro-quote">
        Some of the things I've built, in progress or shipped.
      </blockquote>
      {stack.length > 0 && (
        <p class="mt-4 text-[15px] font-mono text-muted tracking-wide lowercase flex flex-wrap gap-x-3 gap-y-1 items-baseline">
          <span>stack:</span>
          {stack.map((t) => (
            <button type="button" class="tag-toggle hover:text-accent transition-colors" data-tag={t}>{t}</button>
          ))}
          <span class="ml-auto flex items-baseline gap-1">
            match
            <button type="button" id="filter-mode" class="border border-divider rounded px-1.5 py-0.5 hover:text-accent">all</button>
          </span>
        </p>
      )}
    </header>

    <ul class="mt-10 space-y-8">
      {items.map((p) => {
        const detail = p.body && p.body.trim().length > 0;
        const href = detail
          ? `${base}/projects/${p.slug}`
          : p.data.links.site ?? p.data.links.repo ?? `${base}/projects/${p.slug}`;
        const external = !!(!detail && (p.data.links.site || p.data.links.repo));
        return (
          <li class="filter-item flex gap-5 items-start bg-surface-soft rounded-lg p-5" data-tags={p.data.stack.join('|')}>
            <div class="min-w-0 flex-1">
              <div class="text-[14px] font-mono text-muted opacity-60 tracking-wide">
                <span>{p.data.year}</span>
                {p.data.featured && (<><span class="mx-1.5">·</span><span>featured</span></>)}
              </div>
              <p class="mt-1 text-[18px]">
                <a class="text-accent hover:underline" href={href} {...(external ? { rel: 'noopener', target: '_blank' } : {})}>
                  {p.data.name}{external && ' ↗'}
                </a>
              </p>
              <Description text={p.data.oneLiner} />
              <TagList tags={p.data.stack} basePath="" mode="toggle" />
              {(p.data.links.repo || p.data.links.site) && (
                <p class="mt-2 flex items-center gap-3 text-muted">
                  {p.data.links.repo && (
                    <a class="inline-flex items-center hover:text-accent" href={p.data.links.repo} rel="noopener" target="_blank" aria-label="GitHub repo" title="GitHub repo">
                      <Icon name="github" size={14} />
                    </a>
                  )}
                  {p.data.links.site && (
                    <a class="inline-flex items-center text-[15px] font-mono hover:text-accent" href={p.data.links.site} rel="noopener" target="_blank">
                      site ↗
                    </a>
                  )}
                </p>
              )}
            </div>
            <PostCover slug={p.slug} size={96} />
          </li>
        );
      })}
      {items.length === 0 && <li class="text-muted text-sm">no projects yet.</li>}
    </ul>
    <p id="filter-empty" class="hidden mt-10 text-sm text-muted italic">
      No projects match the selected stack tags. Toggle a tag off to widen the filter.
    </p>
  </main>
</BaseLayout>
<FilterScript />
