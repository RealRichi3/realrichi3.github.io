---
import BaseLayout from '../layouts/BaseLayout.astro';
import NumberedSection from '../components/NumberedSection.astro';
import ExperienceList from '../components/ExperienceList.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<BaseLayout title="Experience — Richie Moluno">
  <main class="max-w-content mx-auto px-6 pb-12">
    <NumberedSection label="Experience">
      <p class="text-sm">
        <a class="text-accent" href={`${base}/resume.pdf`}>Download resume (PDF) ↓</a>
      </p>
      <div class="mt-8">
        <ExperienceList />
      </div>
    </NumberedSection>
  </main>
</BaseLayout>
