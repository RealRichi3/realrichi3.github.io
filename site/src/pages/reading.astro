---
import BaseLayout from '../layouts/BaseLayout.astro';
import ReadingList from '../components/ReadingList.astro';
import FilterScript from '../components/FilterScript.astro';
import { getReading } from '../lib/reading';

const all = getReading()
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const tagSet = new Set<string>();
all.forEach((r) => r.data.tags.forEach((t) => tagSet.add(t)));
const tags = Array.from(tagSet).sort();
---
<BaseLayout title="Bookmarks - Richie Moluno">
  <main class="max-w-content mx-auto px-6 pb-4 flex flex-col min-h-[calc(100vh-8rem)]">
    <header class="mt-12">
      <blockquote class="intro-quote">
        Things I found worth a click. Newest first. Toggle a tag to filter.
      </blockquote>
      {tags.length > 0 && (
        <p class="mt-4 text-[13px] font-mono text-muted tracking-wide lowercase flex flex-wrap gap-x-3 gap-y-1 items-baseline">
          <span>tags:</span>
          {tags.map((t) => (
            <button type="button" class="tag-toggle hover:text-accent transition-colors" data-tag={t}>{t}</button>
          ))}
          <span class="ml-auto flex items-baseline gap-1">
            match
            <button type="button" id="filter-mode" class="border border-divider rounded px-1.5 py-0.5 hover:text-accent">all</button>
          </span>
        </p>
      )}
    </header>

    <ReadingList items={all} />
    <p id="filter-empty" class="hidden mt-10 text-sm text-muted italic">
      No bookmarks match the selected tags. Toggle a tag off to widen the filter.
    </p>
  </main>
</BaseLayout>
<FilterScript />
